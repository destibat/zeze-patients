# =============================================================================
# Variables d'environnement — ZEZEPAGNON Dossiers Patients
# Copier ce fichier en .env.development (dev) ou .env.production (prod)
# NE JAMAIS COMMITER les fichiers .env remplis
# =============================================================================

# Environnement
NODE_ENV=development

# Serveur
PORT=3000

# Base de données MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zezepagnon_dev
DB_USER=root
DB_PASSWORD=P@ssW0rd

# JWT — générer avec : node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=CHANGER_CE_SECRET_MIN_64_CARACTERES_ALEATOIRES
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGER_CE_REFRESH_SECRET_MIN_64_CARACTERES_ALEATOIRES
JWT_REFRESH_EXPIRES_IN=7d

# Uploads
UPLOAD_MAX_SIZE_MB=20
UPLOAD_PATH=./uploads

# Logs
LOG_LEVEL=debug
LOG_DIR=./logs

# Application
APP_NAME=ZEZEPAGNON Dossiers Patients
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
