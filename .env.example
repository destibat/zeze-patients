# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter le fichier .env

# Base de données
DB_ROOT_PASSWORD=changez_ce_mot_de_passe
DB_NAME=zezepagnon_prod
DB_USER=zezepagnon
DB_PASSWORD=changez_ce_mot_de_passe

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez_ce_secret_min_64_caracteres
JWT_REFRESH_SECRET=changez_ce_secret_min_64_caracteres

# URL du frontend en production (pour CORS)
FRONTEND_URL=https://patients.zezepagnon.solutions
